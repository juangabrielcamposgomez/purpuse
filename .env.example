# ----------------------------------------------------------------------------
# Purpose360 AI - Environment Configuration
# ----------------------------------------------------------------------------
# LOCAL DEV:   cp .env.example .env, then fill in secrets
# PRODUCTION:  Set these vars in your deployment platform (Vercel, LangGraph Cloud)
# ----------------------------------------------------------------------------

# --- 1. SUPABASE (Backend & Database) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://user:pass@db.your-project.supabase.co:5432/postgres

# --- 2. AI MODELS ---
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
AGENT_RUNTIME=gemini-flash-deep

# --- 3. COPILOTKIT (Vercel) ---
COPILOTKIT_LICENSE_TOKEN=your-license-token
NEXT_PUBLIC_COPILOTKIT_LICENSE_TOKEN=your-public-license-token

# --- 4. COPILOTKIT INTELLIGENCE (Cloud — threads persistence) ---
# Production cloud URLs (no fallback to localhost):
INTELLIGENCE_API_URL=https://api.cloud.copilotkit.ai/v1
INTELLIGENCE_GATEWAY_WS_URL=wss://api.cloud.copilotkit.ai/v1
INTELLIGENCE_API_KEY=your-cloud-intelligence-key

# --- 5. LANGGRAPH AGENT (Python — deploy to LangGraph Cloud) ---
LANGGRAPH_DEPLOYMENT_URL=https://your-deployment.langgraph.app
LANGGRAPH_RECURSION_LIMIT=60
# AGENT_ENV=production  ← uncomment in LangGraph Cloud to enable production mode

# --- 6. MCP SERVER (Manufact Cloud or Railway) ---
MCP_SERVER_URL=https://your-mcp-deployment.com/mcp

# --- 7. NOTION INTEGRATION ---
NOTION_TOKEN=your-notion-token
NOTION_LEADS_DATABASE_ID=your-database-id

# --- 8. OPTIONAL ---
LANGSMITH_API_KEY=your-langsmith-key
